{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": ["NODE_ENV", "KERNEL_VERSION"],
  "pipeline": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".dist/**", ".next/**", "pkg/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["build"]
    }
  }
}
